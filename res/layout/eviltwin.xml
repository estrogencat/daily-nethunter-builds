<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/eviltwin_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <!-- Card 1: Target Configuration -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="@android:color/transparent">

                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_orange_light"
                    android:paddingBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TARGET CONFIGURATION"/>

                <!-- Monitor Interface Label -->
                <TextView
                    android:textSize="12sp"
                    android:textColor="@android:color/holo_orange_light"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Monitor Interface"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    app:cardCornerRadius="4dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@android:color/holo_orange_light"
                    app:strokeWidth="2dp">

                    <Spinner
                        android:id="@+id/eviltwin_interface"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:spinnerMode="dropdown"
                        android:textColor="@android:color/white"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Target Network Label -->
                <TextView
                    android:textSize="12sp"
                    android:textColor="@android:color/holo_orange_light"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"
                    android:text="Target Network"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    app:cardCornerRadius="4dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@android:color/holo_orange_light"
                    app:strokeWidth="2dp">

                    <Spinner
                        android:id="@+id/eviltwin_target"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:spinnerMode="dropdown"
                        android:textColor="@android:color/white"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/eviltwin_channel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Channel: --"
                    android:textColor="@android:color/holo_orange_light"
                    android:textSize="14sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 2: Scan Button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:gravity="center">

                <Button
                    android:id="@+id/eviltwin_scan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SCAN NETWORKS"
                    android:textColor="@android:color/holo_orange_light"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 3: AP Configuration -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="@android:color/transparent">

                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_orange_light"
                    android:paddingBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FAKE ACCESS POINT"/>

                <RadioGroup
                    android:id="@+id/eviltwin_ap_source"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/eviltwin_ap_virtual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Virtual AP from wlan0"
                        android:textColor="@android:color/white"
                        android:checked="true"/>

                    <RadioButton
                        android:id="@+id/eviltwin_ap_existing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Use External Adapter"
                        android:textColor="@android:color/white"/>

                </RadioGroup>

                <TextView
                    android:textSize="12sp"
                    android:textColor="@android:color/holo_orange_light"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="AP Interface Name"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    app:cardCornerRadius="4dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@android:color/holo_orange_light"
                    app:strokeWidth="2dp">

                    <EditText
                        android:id="@+id/eviltwin_ap_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="wlan3"
                        android:textColor="@android:color/white"
                        android:background="@android:color/transparent"
                        android:padding="8dp"
                        android:hint="AP Interface Name"
                        android:textColorHint="@android:color/darker_gray"/>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 4: Internet Source -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="@android:color/transparent">

                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_orange_light"
                    android:paddingBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="INTERNET SOURCE"/>

                <RadioGroup
                    android:id="@+id/eviltwin_internet_source"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/eviltwin_internet_auto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Auto-detect (recommended)"
                        android:textColor="@android:color/white"
                        android:checked="true"/>

                    <RadioButton
                        android:id="@+id/eviltwin_internet_wifi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="WiFi (wlan0)"
                        android:textColor="@android:color/white"/>
                </RadioGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 5: Controls - Single Toggle Button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:gravity="center">

                <Button
                    android:id="@+id/eviltwin_start"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="START"
                    android:textColor="@android:color/holo_orange_light"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 6: Output Logs (WITH orange border) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@android:color/holo_orange_light"
            app:strokeWidth="2dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="@android:color/transparent">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="8dp">

                    <TextView
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/holo_orange_light"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OUTPUT"/>

                    <TextView
                        android:textSize="14sp"
                        android:textColor="@android:color/white"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Made by @dr.rootsu"/>

                    <Button
                        android:id="@+id/eviltwin_clear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CLEAR"
                        android:textColor="@android:color/holo_orange_light"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:padding="4dp"
                    app:cardCornerRadius="4dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@android:color/holo_orange_light"
                    app:strokeWidth="2dp">

                    <androidx.core.widget.NestedScrollView
                        android:background="@android:color/black"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:elevation="2dp">

                        <TextView
                            android:id="@+id/eviltwin_log"
                            android:textSize="11sp"
                            android:textColor="#00ff00"
                            android:fontFamily="monospace"
                            android:scrollbars="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Ready. Select options and click START."/>

                    </androidx.core.widget.NestedScrollView>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>